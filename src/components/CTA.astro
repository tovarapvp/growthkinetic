<section class="py-0 overflow-hidden bg-surface-container-low">
  <div class="flex flex-col lg:flex-row">
    <div class="lg:w-1/2 p-12 md:p-24 flex flex-col justify-center">
      <h2 class="text-5xl md:text-7xl font-extrabold font-headline text-on-surface mb-8 tracking-tighter">&iquest;Listo para <br/>dominar <br/><span class="text-primary">tus redes?</span></h2>
      <p class="text-on-surface-variant text-xl mb-12 max-w-md">D&eacute;janos tus datos y un especialista se pondr&aacute; en contacto contigo en menos de 24 horas.</p>
      <div class="space-y-4 text-on-surface-variant font-medium">
        <div class="flex items-center gap-4">
          <span class="material-symbols-outlined text-primary">location_on</span>
          Av. Tech 404, Ciudad Digital
        </div>
      </div>
    </div>

    <div class="lg:w-1/2 bg-surface-container-lowest p-12 md:p-24 border-l border-outline">
      <form action="#" class="space-y-6 max-w-md mx-auto">
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Nombre</label>
          <input class="w-full bg-surface-container-low border border-outline rounded-2xl px-6 py-4 focus:border-primary focus:ring-0 transition-all text-on-surface placeholder:text-on-surface-variant/40" placeholder="Nombre completo" type="text" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Email</label>
          <input class="w-full bg-surface-container-low border border-outline rounded-2xl px-6 py-4 focus:border-primary focus:ring-0 transition-all text-on-surface placeholder:text-on-surface-variant/40" placeholder="Correo electr&oacute;nico" type="email" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Instagram</label>
          <input class="w-full bg-surface-container-low border border-outline rounded-2xl px-6 py-4 focus:border-primary focus:ring-0 transition-all text-on-surface placeholder:text-on-surface-variant/40" placeholder="@usuario_instagram" type="text" />
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-2">Mensaje</label>
          <textarea class="w-full bg-surface-container-low border border-outline rounded-2xl px-6 py-4 focus:border-primary focus:ring-0 transition-all text-on-surface placeholder:text-on-surface-variant/40" placeholder="Cu&eacute;ntanos sobre tu marca..." rows="4"></textarea>
        </div>
        <button class="w-full bg-primary text-white py-5 rounded-2xl font-bold text-lg hover:shadow-xl hover:shadow-primary/20 transition-all">Enviar Mensaje</button>
      </form>
    </div>
  </div>
</section>
