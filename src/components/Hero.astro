---

<section class="relative pt-48 pb-32 px-6 hero-gradient flex flex-col items-center text-center">
  <div class="max-w-4xl mx-auto z-10">
    <span class="inline-block px-4 py-1.5 rounded-full bg-primary-fixed text-on-surface text-[0.6875rem] font-bold uppercase tracking-[0.2em] mb-8 border border-primary/10">Expertos en Crecimiento</span>
    <h1 class="text-6xl lg:text-8xl font-extrabold font-headline leading-[1] tracking-tighter text-on-surface mb-8">
      Hacemos crecer tu marca en <br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-amber-400 to-primary bg-[length:200%_auto] animate-gradient">redes sociales</span>
    </h1>
    <p class="text-xl text-on-surface-variant max-w-2xl mx-auto mb-12 leading-relaxed">
      Estrategia, creaci&oacute;n de contenido y gesti&oacute;n de comunidades dise&ntilde;ada para convertir seguidores en clientes leales.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-24">
      <button class="bg-primary text-on-primary px-10 py-4 rounded-full font-bold text-lg hover:shadow-lg hover:shadow-primary/20 transition-all flex items-center justify-center gap-2">
        Agenda tu consulta gratis
        <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </div>
  </div>

  <!-- Integrated Phone Mockup -->
  <div class="relative w-full max-w-4xl px-4">
    <div class="relative z-10 mx-auto w-[280px] h-[580px] bg-neutral-900 rounded-[3rem] p-3 shadow-2xl border-4 border-outline-variant overflow-hidden rotate-[-2deg] hover:rotate-0 transition-transform duration-700">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-neutral-900 rounded-b-2xl z-20"></div>
      <img alt="Phone Mockup" class="w-full h-full object-cover rounded-[2.2rem]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8iwTuOR04ZHsab7qHAjKvkG_B7zKBIulC0pdBOvjDyFbKCa-cfP4sa-BFjrdXzt2P08J_edG9RZb-vSFl3MX3GY33jXylUScvpcOqQjNK0D1aneoT12zmDEQrEI6G3kivGAuUKmLXKjVy6F3Q2VzFPGmdxeH092f3HR6BmmI4h9zxIiWDC6pE4zT2hvViwlZy-4dffRmw9Dw2xaHg8XTY9l2TUlzvznG9jvcUet40wiPoLMPFFlfGtypEhhD6-L3K1-le766g4Ac" />
    </div>

    <!-- Floating Elements -->
    <div class="absolute right-[10%] top-10 glass-card p-5 rounded-2xl border border-outline shadow-xl animate-bounce" style="animation-duration: 4s;">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-primary">trending_up</span>
        </div>
        <div class="text-left">
          <p class="text-[0.625rem] text-on-surface-variant font-bold uppercase tracking-wider">Crecimiento</p>

          <p class="text-xl font-bold font-headline text-on-surface">+324%</p>
        </div>
      </div>
    </div>

    <div class="absolute left-[10%] bottom-20 glass-card p-5 rounded-2xl border border-outline shadow-xl animate-bounce" style="animation-duration: 5s; animation-delay: 1s;">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-secondary-container rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-secondary">favorite</span>
        </div>
        <div class="text-left">
          <p class="text-[0.625rem] text-on-surface-variant font-bold uppercase tracking-wider">Engagement</p>
          <p class="text-xl font-bold font-headline text-on-surface">12.5k</p>
        </div>
      </div>
    </div>
  </div>
</section>
