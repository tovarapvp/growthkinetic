---
---

<section class="py-32 px-6 bg-surface-variant" id="pricing">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <span class="label-sm text-primary font-bold tracking-[0.2em] mb-4 block">PLANES</span>
      <h2 class="text-4xl md:text-6xl font-extrabold font-headline text-on-surface">Inversi&oacute;n en Crecimiento</h2>
    </div>

    <div class="space-y-6">
      <!-- Starter -->
      <div class="bg-surface-container-lowest p-8 md:p-12 rounded-[2rem] border border-outline flex flex-col md:flex-row md:items-center gap-8 group hover:border-primary transition-all shadow-sm">
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-on-surface mb-2">Inicial</h3>
          <p class="text-on-surface-variant">Ideal para marcas nuevas.</p>
        </div>
        <div class="flex-1">
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> 3 posts/semana</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> Gesti&oacute;n 2 redes</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> Reporte mensual</li>
          </ul>
        </div>
        <div class="md:text-right">
          <div class="text-3xl font-black text-on-surface mb-4">$499<span class="text-sm font-normal text-on-surface-variant">/mes</span></div>
          <button class="bg-surface-container-low px-8 py-3 rounded-full text-on-surface font-bold border border-outline group-hover:bg-primary group-hover:text-white group-hover:border-primary transition-all">Seleccionar</button>
        </div>
      </div>

      <!-- Growth (Featured) -->
      <div class="bg-primary text-white p-8 md:p-12 rounded-[2rem] flex flex-col md:flex-row md:items-center gap-8 shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 p-4">
          <span class="bg-surface-container-lowest/20 text-[0.625rem] px-3 py-1 rounded-full font-bold uppercase tracking-widest text-white">M&aacute;s Popular</span>
        </div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold mb-2">Crecimiento</h3>
          <p class="opacity-80 text-white">Para marcas escalando.</p>
        </div>
        <div class="flex-1">
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm font-medium">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined scale-75">check_circle</span> 5 posts + Reels</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined scale-75">check_circle</span> Gesti&oacute;n 4 redes</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined scale-75">check_circle</span> Comunidad</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined scale-75">check_circle</span> Ads b&aacute;sico</li>
          </ul>
        </div>
        <div class="md:text-right">
          <div class="text-3xl font-black mb-4">$999<span class="text-sm font-normal opacity-70">/mes</span></div>
          <button class="bg-surface-container-lowest text-primary px-8 py-3 rounded-full font-bold hover:shadow-lg transition-all">Empezar Ahora</button>
        </div>
      </div>

      <!-- Premium -->
      <div class="bg-surface-container-lowest p-8 md:p-12 rounded-[2rem] border border-outline flex flex-col md:flex-row md:items-center gap-8 group hover:border-primary transition-all shadow-sm">
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-on-surface mb-2">Premium</h3>
          <p class="text-on-surface-variant">Dominio total del mercado.</p>
        </div>
        <div class="flex-1">
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-on-surface-variant">
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> Contenido ilimitado</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> Eventos</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> SEO Social</li>
            <li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary scale-75">check_circle</span> Soporte 24/7</li>
          </ul>
        </div>
        <div class="md:text-right">
          <div class="text-3xl font-black text-on-surface mb-4">$1,899<span class="text-sm font-normal text-on-surface-variant">/mes</span></div>
          <button class="bg-surface-container-low px-8 py-3 rounded-full text-on-surface font-bold border border-outline group-hover:bg-primary group-hover:text-white group-hover:border-primary transition-all">Seleccionar</button>
        </div>
      </div>
    </div>
  </div>
</section>
